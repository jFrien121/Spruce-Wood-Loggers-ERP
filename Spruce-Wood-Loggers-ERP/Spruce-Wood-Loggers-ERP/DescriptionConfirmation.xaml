<UserControl x:Class="Spruce_Wood_Loggers_ERP.DescriptionConfirmation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Spruce_Wood_Loggers_ERP"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="330" d:DesignWidth="650">
    <Grid Background="White">
		<!--<Separator Margin="20,0,20,0"/>-->

		<StackPanel>

			<!-- Grade options -->
			<StackPanel
			Margin="20"
			Orientation="Horizontal"
			VerticalAlignment="Top">
				<TextBlock
					Text="Grade: "
					FontWeight="Bold"
					FontSize="20"/>

				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					VerticalContentAlignment="Center"
					IsChecked="True"
					Margin="15,0"
					VerticalAlignment="Stretch">
					<TextBlock
						Text="Ungraded"
						FontSize="20"
						Margin="0,-3,0,0"/>
				</RadioButton>
				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					VerticalAlignment="Center"
					Margin="15,0">
					<TextBlock
					Text="#1"
					FontSize="20"
					Margin="0,-3,0,0"/>
				</RadioButton>
				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					Margin="15,0">
					<TextBlock
					Text="#2"
					FontSize="20"
					Margin="0,-3,0,0"/>
				</RadioButton>
				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					Margin="15,0">
					<TextBlock
					Text="#3"
					FontSize="20"
					Margin="0,-3,0,0"/>
				</RadioButton>

			</StackPanel>
		
			<Rectangle Height="1"
			   Fill="LightGray"
			   HorizontalAlignment="Stretch"
			   Margin="20,0,20,0"/>

			<!-- Number of pieces options -->
			<StackPanel
				Margin="20"
				Orientation="Horizontal"
				VerticalAlignment="Center">
				<TextBlock
					Text="Number of Pieces: "
					FontWeight="Bold"
					FontSize="20"
					VerticalAlignment="Center"/>

				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					VerticalContentAlignment="Center"
					IsChecked="True"
					Margin="15,0">
					<ComboBox
						x:Name="OutlinedComboBox"
						Width="150"
						Height="40"
						FontSize="15"
						Padding="10,2"
						Margin="7,0"
						materialDesign:HintAssist.Hint="Standard"
						IsEnabled="True"
						Style="{StaticResource MaterialDesignOutlinedComboBox}">
						<ComboBoxItem Content="Option 1"/>
						<ComboBoxItem Content="Option 2"/>
						<ComboBoxItem Content="Option 3"/>
						<ComboBoxItem Content="Option 4"/>
					</ComboBox>
				</RadioButton>
				<RadioButton
					Style="{StaticResource MaterialDesignRadioButton}"
					FontSize="20"
					VerticalAlignment="Center"
					Margin="15,0">
					<TextBox
						Height="40"
						Width="150"
						Margin="7,0"
						FontSize="15"
						Padding="10,2"
						materialDesign:HintAssist.Hint="Custom"
						AcceptsReturn="True"
						IsEnabled="True"
						Style="{StaticResource MaterialDesignOutlinedTextBox}"
						PreviewTextInput="NumberOnly_PreviewTextInput"
						DataObject.Pasting="NumberOnly_Pasting"/>
				</RadioButton>

			</StackPanel>

			<Rectangle Height="1"
			   Fill="LightGray"
			   HorizontalAlignment="Stretch"
			   Margin="20,0,20,0"/>

			<TextBlock
				Margin="0,30,0,10"
				Text="1&quot; x 3&quot; x 4' Ungraded&#x0A;x 240 pieces"
				TextWrapping="Wrap"
				FontSize="20"
				HorizontalAlignment="Center"
				TextAlignment="Center"
				FontWeight="DemiBold"/>

			<StackPanel
				Margin="10"
				HorizontalAlignment="Center"
				Orientation="Horizontal">
				<Button Grid.Row="1" Grid.Column="1"
					Margin="10,0"
					materialDesign:ButtonAssist.CornerRadius="5"
					Width="130"
					Height="40"
					IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
					Style="{StaticResource MaterialDesignRaisedLightButton}"
					ToolTip="MaterialDesignRaisedLightButton with Round Corners"
					Padding="2px"
					Content="Confirm"
					FontSize="20"/>
				<Button Grid.Row="1" Grid.Column="1"
					Margin="10,0"
					materialDesign:ButtonAssist.CornerRadius="5"
					Width="130"
					Height="40"
					IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
					Style="{StaticResource MaterialDesignPaperLightButton}"
					ToolTip="MaterialDesignRaisedLightButton with Round Corners"
					Padding="2px"
					Content="Cancel"
						FontSize="20"/>
			</StackPanel>


		</StackPanel>
	</Grid>
</UserControl>
